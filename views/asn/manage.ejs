<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ASN入库单管理系统</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/views/asn/manage">
                <i class="fas fa-warehouse me-2"></i>ASN入库单管理系统
            </a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-list me-2"></i>入库单管理
                        </h5>
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createReceiptModal">
                            <i class="fas fa-plus me-1"></i>创建入库单
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ASN单号</th>
                                        <th>供应商</th>
                                        <th>入库日期</th>
                                        <th>入库类型</th>
                                        <th>仓库</th>
                                        <th>总金额</th>
                                        <th>状态</th>
                                        <th>操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (receipts && receipts.length > 0) { %>
                                        <% receipts.forEach(receipt => { %>
                                            <tr>
                                                <td><strong><%= receipt.asn_number %></strong></td>
                                                <td><%= receipt.supplier_name %></td>
                                                <td><%= new Date(receipt.receipt_date).toLocaleDateString('zh-CN') %></td>
                                                <td><%= receipt.receipt_type %></td>
                                                <td><%= receipt.warehouse %></td>
                                                <td>¥<%= receipt.total_amount.toLocaleString() %></td>
                                                <td>
                                                    <% if (receipt.status === 'pending') { %>
                                                        <span class="badge bg-warning">待处理</span>
                                                    <% } else if (receipt.status === 'processing') { %>
                                                        <span class="badge bg-info">处理中</span>
                                                    <% } else if (receipt.status === 'completed') { %>
                                                        <span class="badge bg-success">已完成</span>
                                                    <% } else if (receipt.status === 'cancelled') { %>
                                                        <span class="badge bg-danger">已取消</span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a href="/views/asn/detail/<%= receipt.id %>" class="btn btn-outline-primary" title="查看详情">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <% if (receipt.status === 'pending') { %>
                                                            <button class="btn btn-outline-success" onclick="updateStatus('<%= receipt.id %>', 'processing')" title="开始处理">
                                                                <i class="fas fa-play"></i>
                                                            </button>
                                                        <% } %>
                                                        <% if (receipt.status === 'processing') { %>
                                                            <button class="btn btn-outline-success" onclick="updateStatus('<%= receipt.id %>', 'completed')" title="完成入库">
                                                                <i class="fas fa-check"></i>
                                                            </button>
                                                        <% } %>
                                                        <% if (receipt.status !== 'completed') { %>
                                                            <button class="btn btn-outline-danger" onclick="updateStatus('<%= receipt.id %>', 'cancelled')" title="取消">
                                                                <i class="fas fa-times"></i>
                                                            </button>
                                                        <% } %>
                                                        <button class="btn btn-outline-danger" onclick="deleteReceipt('<%= receipt.id %>')" title="删除">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="8" class="text-center text-muted py-4">
                                                暂无入库单记录
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 创建入库单模态框 -->
    <div class="modal fade" id="createReceiptModal" tabindex="-1" aria-labelledby="createReceiptModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createReceiptModalLabel">
                        <i class="fas fa-plus me-2"></i>创建新入库单
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="createReceiptForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="supplier_name" class="form-label">供应商名称 *</label>
                                    <input type="text" class="form-control" id="supplier_name" name="supplier_name" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="supplier_contact" class="form-label">供应商联系方式</label>
                                    <input type="text" class="form-control" id="supplier_contact" name="supplier_contact">
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="receipt_date" class="form-label">入库日期 *</label>
                                    <input type="date" class="form-control" id="receipt_date" name="receipt_date" required>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="receipt_type" class="form-label">入库类型 *</label>
                                    <select class="form-select" id="receipt_type" name="receipt_type" required>
                                        <option value="">请选择入库类型</option>
                                        <option value="采购入库">采购入库</option>
                                        <option value="退货入库">退货入库</option>
                                        <option value="调拨入库">调拨入库</option>
                                        <option value="生产入库">生产入库</option>
                                        <option value="其他入库">其他入库</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="warehouse" class="form-label">仓库 *</label>
                                    <select class="form-select" id="warehouse" name="warehouse" required>
                                        <option value="">请选择仓库</option>
                                        <option value="主仓库">主仓库</option>
                                        <option value="分仓库A">分仓库A</option>
                                        <option value="分仓库B">分仓库B</option>
                                        <option value="临时仓库">临时仓库</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="remarks" class="form-label">备注</label>
                            <textarea class="form-control" id="remarks" name="remarks" rows="2"></textarea>
                        </div>

                        <hr>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0">商品明细</h6>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addItemRow()">
                                <i class="fas fa-plus me-1"></i>添加商品
                            </button>
                        </div>
                        
                        <div id="itemsContainer">
                            <div class="item-row mb-3">
                                <div class="row">
                                    <div class="col-md-3">
                                        <input type="text" class="form-control" name="product_name" placeholder="商品名称 *" required>
                                    </div>
                                    <div class="col-md-2">
                                        <input type="text" class="form-control" name="product_code" placeholder="商品编码">
                                    </div>
                                    <div class="col-md-2">
                                        <input type="text" class="form-control" name="specification" placeholder="规格型号">
                                    </div>
                                    <div class="col-md-2">
                                        <input type="number" class="form-control" name="quantity" placeholder="数量 *" min="1" required onchange="calculateTotal(this)">
                                    </div>
                                    <div class="col-md-2">
                                        <input type="number" class="form-control" name="unit_price" placeholder="单价 *" min="0" step="0.01" required onchange="calculateTotal(this)">
                                    </div>
                                    <div class="col-md-1">
                                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeItemRow(this)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="button" class="btn btn-primary" onclick="submitCreateForm()">创建入库单</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/asn-manage.js"></script>
</body>
</html>