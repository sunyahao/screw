<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>入库单详情 - ASN入库单管理系统</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/views/asn/manage">
                <i class="fas fa-warehouse me-2"></i>ASN入库单管理系统
            </a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/views/asn/manage">入库单管理</a></li>
                        <li class="breadcrumb-item active" aria-current="page">入库单详情</li>
                    </ol>
                </nav>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-file-alt me-2"></i>入库单详情
                        </h5>
                        <div>
                            <% if (receipt.status === 'pending') { %>
                                <span class="badge bg-warning fs-6">待处理</span>
                            <% } else if (receipt.status === 'processing') { %>
                                <span class="badge bg-info fs-6">处理中</span>
                            <% } else if (receipt.status === 'completed') { %>
                                <span class="badge bg-success fs-6">已完成</span>
                            <% } else if (receipt.status === 'cancelled') { %>
                                <span class="badge bg-danger fs-6">已取消</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <strong>ASN单号：</strong>
                                <span class="text-primary"><%= receipt.asn_number %></span>
                            </div>
                            <div class="col-md-4">
                                <strong>供应商：</strong>
                                <%= receipt.supplier_name %>
                            </div>
                            <div class="col-md-4">
                                <strong>联系方式：</strong>
                                <%= receipt.supplier_contact || '未填写' %>
                            </div>
                        </div>
                        
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <strong>入库日期：</strong>
                                <%= new Date(receipt.receipt_date).toLocaleDateString('zh-CN') %>
                            </div>
                            <div class="col-md-4">
                                <strong>入库类型：</strong>
                                <%= receipt.receipt_type %>
                            </div>
                            <div class="col-md-4">
                                <strong>仓库：</strong>
                                <%= receipt.warehouse %>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <strong>创建时间：</strong>
                                <%= new Date(receipt.created_at).toLocaleString('zh-CN') %>
                            </div>
                            <div class="col-md-4">
                                <strong>更新时间：</strong>
                                <%= new Date(receipt.updated_at).toLocaleString('zh-CN') %>
                            </div>
                            <div class="col-md-4">
                                <strong>总金额：</strong>
                                <span class="text-success fw-bold">¥<%= receipt.total_amount.toLocaleString() %></span>
                            </div>
                        </div>

                        <% if (receipt.remarks) { %>
                        <div class="row mb-4">
                            <div class="col-12">
                                <strong>备注：</strong>
                                <p class="mt-2 p-3 bg-light rounded"><%= receipt.remarks %></p>
                            </div>
                        </div>
                        <% } %>

                        <hr>
                        
                        <h6 class="mb-3">
                            <i class="fas fa-boxes me-2"></i>商品明细
                        </h6>
                        
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>序号</th>
                                        <th>商品名称</th>
                                        <th>商品编码</th>
                                        <th>规格型号</th>
                                        <th>数量</th>
                                        <th>单价</th>
                                        <th>总价</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (items && items.length > 0) { %>
                                        <% items.forEach((item, index) => { %>
                                            <tr>
                                                <td><%= index + 1 %></td>
                                                <td><%= item.product_name %></td>
                                                <td><%= item.product_code || '-' %></td>
                                                <td><%= item.specification || '-' %></td>
                                                <td><%= item.quantity %></td>
                                                <td>¥<%= item.unit_price.toLocaleString() %></td>
                                                <td class="fw-bold">¥<%= item.total_price.toLocaleString() %></td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">
                                                暂无商品明细
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                                <% if (items && items.length > 0) { %>
                                <tfoot class="table-light">
                                    <tr>
                                        <th colspan="6" class="text-end">合计：</th>
                                        <th class="text-success">¥<%= receipt.total_amount.toLocaleString() %></th>
                                    </tr>
                                </tfoot>
                                <% } %>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="d-flex justify-content-between">
                            <a href="/views/asn/manage" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>返回列表
                            </a>
                            <div>
                                <% if (receipt.status === 'pending') { %>
                                    <button class="btn btn-info me-2" onclick="updateStatus('<%= receipt.id %>', 'processing')">
                                        <i class="fas fa-play me-1"></i>开始处理
                                    </button>
                                <% } %>
                                <% if (receipt.status === 'processing') { %>
                                    <button class="btn btn-success me-2" onclick="updateStatus('<%= receipt.id %>', 'completed')">
                                        <i class="fas fa-check me-1"></i>完成入库
                                    </button>
                                <% } %>
                                <% if (receipt.status !== 'completed') { %>
                                    <button class="btn btn-warning" onclick="updateStatus('<%= receipt.id %>', 'cancelled')">
                                        <i class="fas fa-times me-1"></i>取消入库
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/asn-manage.js"></script>
</body>
</html>